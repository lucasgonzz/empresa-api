APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# pusher: eventos de soporte a empresa-spa (mismas claves que admin-api + Vite).
BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

COMMERCIOCITY_BRAND_NAME=ComercioCity
COMMERCIOCITY_LOGO_URL=
COMMERCIOCITY_HEADER_BG=#38bdf8
COMMERCIOCITY_WEBSITE_URL=https://commerciocity.com
COMMERCIOCITY_INSTAGRAM_URL=https://instagram.com/commerciocity
COMMERCIOCITY_WEBSITE_LABEL=Sitio web
COMMERCIOCITY_INSTAGRAM_LABEL=Instagram
COMMERCIOCITY_FOOTER_LEGAL_HTML=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
# SSL al API REST de Pusher (Guzzle). En local por defecto verify=false si APP_ENV!=production.
# PUSHER_GUZZLE_VERIFY_SSL=false
# PUSHER_GUZZLE_CA_BUNDLE="C:/path/cacert.pem"

# SSL hacia api.mercadolibre.com (cURL error 60 en WAMP). Por defecto verify=false si APP_ENV no es production.
# MERCADO_LIBRE_GUZZLE_VERIFY_SSL=false
# MERCADO_LIBRE_GUZZLE_CA_BUNDLE="C:/wamp64/bin/php/php8.x.x/extras/ssl/cacert.pem"

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Integración con admin-api (sistema central de releases/versiones)
ADMIN_API_URL=http://localhost/empresa/admin-api/public
ADMIN_API_INBOUND_KEY=
ADMIN_API_OUTBOUND_KEY=
ADMIN_API_CLIENT_UUID=

